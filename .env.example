# ╔══════════════════════════════════════════════════════════╗
# ║  APEX BOT — Paper Trading Konfigurácia                  ║
# ║  Skopíruj ako .env  |  NIKDY nezdieľaj!                 ║
# ╚══════════════════════════════════════════════════════════╝

# ── Binance API (Read-only pre paper trading) ────────────────
# Vytvor na: binance.com → Profil → API Management
# Povolenia pre paper trading: ✅ Enable Reading ONLY
# ❌ Vypni: Spot Trading, Withdrawals
BINANCE_API_KEY=sem_vloz_api_key
BINANCE_API_SECRET=sem_vloz_api_secret

# ── Obchodovanie ─────────────────────────────────────────────
SYMBOL=BNB/USDT
TEST_MODE=true              # VŽDY true pre paper trading!

# ── Grid parametre ────────────────────────────────────────────
GRID_LEVELS=8
GRID_STEP_PCT=1.2
ORDER_AMOUNT_USDT=15

# ── Kapitál a ciele ───────────────────────────────────────────
BASE_CAPITAL=10000          # tvoj základný vklad v USDT
DAILY_TARGET=100            # denný ziskový cieľ v USDT
STOP_LOSS_PCT=8.0

# ── Časovanie ────────────────────────────────────────────────
LOOP_INTERVAL_SEC=60        # 1 tick každú minútu

# ── Telegram notifikácie (odporúčam nastaviť) ────────────────
# 1. @BotFather → /newbot → získaš TOKEN
# 2. Napíš botovi /start
# 3. api.telegram.org/bot<TOKEN>/getUpdates → "chat":{"id":...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Audit logging ─────────────────────────────────────────────
SESSION_LOG=paper_session.jsonl

# ── Deployment ────────────────────────────────────────────────
# Nastav na true len ak chceš preskočiť pre-flight gate (debug)
SKIP_PREFLIGHT=false
